---
import ArrowRight from '../assets/icons/arrow-right.svg';

const { tool, class: className } = Astro.props;
const { title, description } = tool.data;
---

<a
  class:list={['group flex items-start justify-between gap-8', className]}
  href={`/tools/${tool.id}/`}
>
  <div class="flex items-start gap-5 grow">

        <!-- LEFT IMAGE -->
    <img
      src="/favicon.svg"
      alt="Tool icon"
      class="hidden h-16 w-16 rounded-md object-cover sm:block transition duration-300 group-hover:-translate-y-1 group-hover:scale-105"
    />

    <!-- TEXT -->
    <div class="grow">

    <h2
      class="font-serif text-xl leading-tight font-medium group-hover:underline group-hover:decoration-dashed group-hover:decoration-1 group-hover:underline-offset-4 sm:text-2xl"
    >
      {title}
    </h2>

    {description && (
      <div class="mt-1 text-sm leading-normal">
        {description}
      </div>
    )}
  </div>
 <!-- RIGHT CTA -->
  <div class="hidden font-serif italic opacity-0 transition group-hover:opacity-100 sm:inline-flex sm:shrink-0 sm:items-center sm:gap-1">
    Open Tool <ArrowRight class="h-4 w-4 fill-current" />
  </div>
</a>

